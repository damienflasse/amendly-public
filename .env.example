# Amendly — Environment variables
# Copy this file to .env and fill in your values.
# .env is never committed to git.
#

# Database
DATABASE_URL=postgresql+asyncpg://amendly:password@db:5432/amendly

# Redis
REDIS_URL=redis://redis:6379

# Auth
BETTER_AUTH_SECRET=                    # legacy env var name; used as the JWT signing secret (generate: openssl rand -hex 32)

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=        # Sender address for transactional emails (default: noreply@amendly.eu)
RESEND_PROSPECT_FROM_EMAIL=                  # Sender address for prospect outreach emails — required in production (e.g. damien@amendly.eu)
RESEND_WEBHOOK_SECRET=                       # Resend webhook signing secret (whsec_...) for /api/webhooks/resend
SUPPORT_INBOX_EMAIL=                         # Internal inbox for /api/contact and /api/support — required in production (e.g. hello@amendly.eu)

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=            # Optional: pre-created Price ID (e.g. price_xxx); if set, overrides inline price_data
STRIPE_PORTAL_RETURN_URL=   # URL the Stripe Customer Portal returns to (e.g. https://app.amendly.eu/orgs/SLUG/billing)

# App
DOMAIN=localhost
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS_RAW=http://localhost:5173
ENVIRONMENT=development                 # development | production

# Proxy trust — set True only when the backend is exclusively reachable
# through a trusted reverse-proxy (nginx, Cloudflare) that injects
# X-Forwarded-Proto.  When False (default) the header is ignored so an
# attacker reaching the backend directly cannot force Secure=False on cookies.
TRUST_PROXY_HEADERS=false               # true in production behind nginx/Cloudflare

# Platform superuser
SUPERUSER_EMAIL=                # Email address that receives is_superuser=True on startup (e.g. admin@amendly.eu); leave empty to disable

# Analytics (Plausible)
# VITE_PLAUSIBLE_DOMAIN: the domain being tracked (data-domain attribute), e.g. example.com
# VITE_PLAUSIBLE_BASE_URL: base URL of your Plausible instance (defaults to https://plausible.io for cloud users)
# The script is injected only after GDPR cookie consent. Leave both empty to disable analytics.
VITE_PLAUSIBLE_DOMAIN=                  # e.g. example.com
VITE_PLAUSIBLE_BASE_URL=               # e.g. https://stats.example.com (omit for plausible.io cloud)
PLAUSIBLE_SECRET_KEY_BASE=              # openssl rand -hex 64  (min 64 chars)
TOTP_VAULT_KEY=                         # openssl rand -base64 32
PLAUSIBLE_DB_PASSWORD=                  # strong password for the Plausible Postgres user
PLAUSIBLE_DB_URL=                       # postgresql://plausible:<password>@plausible-db:5432/plausible
PLAUSIBLE_CLICKHOUSE_DB_URL=            # http://plausible-clickhouse:8123/plausible
# Plausible mailer — reuse Resend SMTP (same API key as main app)
MAILER_EMAIL=                           # e.g. noreply@amendly.eu
SMTP_HOST_ADDR=smtp.resend.com
SMTP_HOST_PORT=465
SMTP_USER_NAME=resend
SMTP_USER_PWD=                          # RESEND_API_KEY value
SMTP_HOST_SSL_ENABLED=true

# Cloudflare Turnstile (bot protection on login and public contribution forms)
# Create a Turnstile widget at https://dash.cloudflare.com → Turnstile.
# Leave empty in local development — the challenge is skipped when the secret is unset.
TURNSTILE_SECRET_KEY=                   # Preferred server-side secret key
CLOUDFLARE_TURNSTILE_SECRET=            # Legacy alias still supported
VITE_TURNSTILE_SITE_KEY=                # Public site key (safe to expose in the browser)
