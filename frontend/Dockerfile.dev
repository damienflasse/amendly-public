# Development-only image — runs Vite dev server with HMR.
# The host frontend/ directory is mounted as a volume so changes are reflected
# immediately without rebuilding the image.
#
# Usage (via docker-compose.dev.yml):
#   docker compose -f docker-compose.dev.yml up -d
#
# Access the app at http://localhost:5173
# API calls are proxied to the backend service at http://backend:8000

FROM node:22-alpine

WORKDIR /app

# Expose Vite's default dev-server port
EXPOSE 5173

# Install node_modules only when the directory is absent (i.e. first boot or
# after the volume is wiped).  On subsequent starts the bind-mounted
# node_modules directory is already populated, so npm install is skipped.
CMD ["sh", "-c", "[ ! -d node_modules ] && npm install; npm run dev"]
